{
  "name": "godot-mcp-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "pnpm build && pnpm lint && pnpm typecheck && pnpm test",
    "qa:phase-0-1": "node scripts/qa-phase-0-1.mjs",
    "qa:phase-2": "node scripts/qa-phase-2.mjs",
    "qa:phase-3": "node scripts/qa-phase-3.mjs",
    "qa:phase-4": "node scripts/qa-phase-4.mjs"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "ws": "8.21.0"
  }
}
